#!/usr/bin/env bash
#
# Installed to /usr/local/sbin/ — runs as root via:
#   sudo -n /usr/local/sbin/xenweet-nginx-install-ssl <domain> <web_root> <key_pem_path> <fullchain_pem_path> <php_fpm_socket> [extra_server_names]
#
# 5th arg: PHP-FPM socket path. The panel must pass it on the command line: sudo does not
# forward PHP_FPM_SOCKET from the environment to this helper.
# 6th arg: space-separated extra server_name entries (optional). sudo does not forward
#   NGINX_EXTRA_SERVER_NAMES; the panel should pass 6th argv. Env is used if 6th is empty.
# Optional env: PHP_FPM_SOCKET (if 5th arg empty; default php8.3)
#
set -euo pipefail
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

DOMAIN="${1:?Usage: $0 <domain> <web_root> <key_pem_path> <fullchain_pem_path> <php_fpm_socket> [extra_server_names]}"
WEB_ROOT="${2:?Usage: $0 <domain> <web_root> <key_pem_path> <fullchain_pem_path> <php_fpm_socket> [extra_server_names]}"
KEY_PATH="${3:?Usage: $0 <domain> <web_root> <key_pem_path> <fullchain_pem_path> <php_fpm_socket> [extra_server_names]}"
FULLCHAIN_PATH="${4:?Usage: $0 <domain> <web_root> <key_pem_path> <fullchain_pem_path> <php_fpm_socket> [extra_server_names]}"
PHP_SOCK="${5:-${PHP_FPM_SOCKET:-/var/run/php/php8.3-fpm.sock}}"
EXTRA_NAMES="${6:-${NGINX_EXTRA_SERVER_NAMES:-}}"
SERVER_NAMES="$DOMAIN"
if [[ -n "$EXTRA_NAMES" ]]; then
  SERVER_NAMES="$DOMAIN $EXTRA_NAMES"
fi

SAFE_NAME="${DOMAIN//[^a-zA-Z0-9._-]/_}"
DEST="/etc/nginx/sites-available/${SAFE_NAME}.conf"
ENABLED="/etc/nginx/sites-enabled/${SAFE_NAME}.conf"

[[ -f "$KEY_PATH" ]] || { echo "ERROR: key PEM not found: $KEY_PATH" >&2; exit 1; }
[[ -f "$FULLCHAIN_PATH" ]] || { echo "ERROR: fullchain PEM not found: $FULLCHAIN_PATH" >&2; exit 1; }

TMP_CONF="$(mktemp)"
cat > "$TMP_CONF" <<EOF
# Xenweet panel — SSL enabled for ${DOMAIN}
server {
    listen 80;
    listen [::]:80;
    server_name ${SERVER_NAMES};

    # Let's Encrypt HTTP-01 (certbot) — must stay on plain HTTP
    location ^~ /.well-known/acme-challenge/ {
        root ${WEB_ROOT};
        default_type "text/plain";
    }

    location / {
        return 301 https://\$host\$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name ${SERVER_NAMES};

    root ${WEB_ROOT};
    index index.php index.html index.htm;

    client_max_body_size 64m;

    ssl_certificate ${FULLCHAIN_PATH};
    ssl_certificate_key ${KEY_PATH};
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    location / {
        try_files \$uri \$uri/ /index.php?\$query_string;
    }

    location ~ \.php\$ {
        include fastcgi_params;
        fastcgi_index index.php;
        fastcgi_param HTTPS on;
        fastcgi_param REQUEST_SCHEME \$scheme;
        fastcgi_param SCRIPT_FILENAME \$document_root\$fastcgi_script_name;
        fastcgi_pass unix:${PHP_SOCK};
    }

    location ~ /\.ht {
        deny all;
    }
}
EOF

cp "$TMP_CONF" "$DEST"
ln -sf "$DEST" "$ENABLED"
nginx -t
systemctl reload nginx
rm -f "$TMP_CONF"

echo "OK: nginx SSL installed (${DEST})"
