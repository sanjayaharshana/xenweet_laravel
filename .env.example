APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Manage DB module MySQL admin connection
# MANAGE_DB_HOST=127.0.0.1
# MANAGE_DB_PORT=3306
# MANAGE_DB_ADMIN_USER=root
# MANAGE_DB_ADMIN_PASSWORD=
# Optional: custom Adminer URL. When unset, the panel uses public/adminer.php (same app origin).
# MANAGE_DB_ADMINER_URL=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# SSL/TLS module: local openssl(1) + Modules/SslTls/bin/ssltls-openssl.sh
# SSLTLS_OPENSSL_BINARY=openssl
# SSLTLS_SCRIPT_PATH=
# Optional: install certificate into Nginx vhost + reload
# SSLTLS_NGINX_SSL_INSTALL_SCRIPT=
# SSLTLS_NGINX_SSL_SYSTEM_INSTALL_BIN=/usr/local/sbin/xenweet-nginx-install-ssl
# SSLTLS_NGINX_SSL_INSTALL_TIMEOUT=90
#
# Let's Encrypt (Auto SSL) — certbot on the app server, optional scheduled renew (php artisan schedule:work or cron)
# SSLTLS_LETSENCRYPT_ENABLED=false
# SSLTLS_LETSENCRYPT_EMAIL=ops@example.com
# SSLTLS_LETSENCRYPT_STAGING=true
# SSLTLS_LETSENCRYPT_CERTBOT=certbot
# SSLTLS_LETSENCRYPT_USE_SUDO=true
# If certbot fails with "sudo: a password is required", on the app server (as root) run:
#   sudo bash scripts/install-xenweet-certbot-sudo.sh www-data
# That script also installs a small helper so the panel can read root-owned privkey.pem / fullchain.pem.
# After upgrading the repo, re-run it so /usr/local/sbin/xenweet-letsencrypt-read-pem stays current.
# SSLTLS_LETSENCRYPT_RENEW_SCHEDULE=false
# SSLTLS_LETSENCRYPT_TIMEOUT=300
# SSLTLS_LETSENCRYPT_RENEW_TIMEOUT=600

VITE_APP_NAME="${APP_NAME}"
